            "value": "your_username",
            "purpose": "輸入使用者帳號"
        },
        {
            "action": "fill",
            "selector": "#txtPassword",
            "value": "your_password",
            "purpose": "輸入密碼"
        },
        {
            "action": "click",
            "selector": "#btnLogin",
            "purpose": "點擊登入按鈕"
        },
        {
            "action": "wait",
            "value": "3000",
            "purpose": "等待登入結果"
        },
        {
